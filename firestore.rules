rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRecipe(data) {
      return data.title is string && data.title.size() <= 200
        && data.time is string && data.time.size() <= 50
        && data.authorId == request.auth.uid
        && data.servings is number
        && data.calories is number
        && data.protein is number
        && data.tags is list
        && data.ingredients is list
        && data.instructions is list;
    }

    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(recipeId) && isValidRecipe(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && isValidId(recipeId) && isValidRecipe(request.resource.data) 
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
  }
}
